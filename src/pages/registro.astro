---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <title>Registro de Paciente</title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
   <body>
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">IPS Salud</a>
            <button id="menu-toggle" class="hamburger" aria-label="Menu">
                &#9776;
            </button>
            <ul class="nav-links">
                <li><a href="/">Inicio</a></li>
                <li><a href="/agendar">Agendar Cita</a></li>
                <li><a href="/#novedades">Novedades</a></li>
                <li><a href="/#aliados-section">Aliados</a></li>
                <li><a href="/#footer">Footer</a></li>
            </ul>
        </div>
    </nav>

<section class="listing">
    <div class="container">
        <div class="form-card">
            <h2>👤 Registro de Paciente</h2>
            <p style="text-align: center; color: var(--text-muted); margin-bottom: 2rem;">Ingresa los datos para habilitar el agendamiento.</p>
            
            <form id="patient-form">
                <label>Nombre Completo
                    <input type="text" id="nombre" placeholder="Nombre y Apellidos" required />
                </label>

                <label>Fecha de Nacimiento
                    <input type="date" id="fecha_nacimiento" required />
                </label>

                <label>Género
                    <select id="genero" required>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="Otro">Otro</option>
                    </select>
                </label>

                <button type="submit" class="btn" style="width: 100%; margin-top: 1rem;">Registrar Paciente</button>
            </form>
        </div>

        <h3 class="section-title" style="font-size: 1.5rem;">Pacientes Recientes</h3>
        <div id="patient-list" class="table-responsive">
            </div>
    </div>
</section>

    <!-- same footer included to maintain design across pages -->
    <footer id="footer" class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>LEGALES</h4>
                    <ul>
                        <li><a href="#">Portabilidad</a></li>
                        <li><a href="#">Protección de datos</a></li>
                        <li><a href="#">Cuotas moderadoras 2025</a></li>
                        <li><a href="#">Canal Anticorrupción</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>SERVICIOS</h4>
                    <ul>
                        <li><a href="#">Gratuidad en Salud</a></li>
                        <li><a href="#">Municipios autorizados</a></li>
                        <li><a href="#">Consulta de remisiones</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>NORMATIVIDAD</h4>
                    <ul>
                        <li><a href="#">Decreto 780 de 2016</a></li>
                        <li><a href="#">Circular 008 de 2018</a></li>
                        <li><a href="#">Reporte de información</a></li>
                    </ul>
                </div>
                <div class="footer-col footer-contact">
                    <img src="/images/vigilado.svg" alt="Vigilado Supersalud" class="vigilado" style="width: 100px; height: auto; margin-bottom: 1rem;" />
                    <p>Línea Nacional: 018000 114524</p>
                    <div class="social-links">
                        <a href="#">FB</a>
                        <a href="#">TW</a>
                        <a href="#">IG</a>
                        <a href="#">IN</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 IPS Salud - Todos los derechos reservados. Vigilado Supersalud.</p>
            </div>
        </div>
    </footer>
</body>
</html>
