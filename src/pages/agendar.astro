---
---
<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>Agendar Cita</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">IPS Salud</a>
            <button id="menu-toggle" class="hamburger" aria-label="Menu">
                &#9776;
            </button>
            <ul class="nav-links">
                <li><a href="/">Inicio</a></li>
                <li><a href="/agendar">Agendar Cita</a></li>
                <li><a href="/#novedades">Novedades</a></li>
                <li><a href="/#aliados-section">Aliados</a></li>
                <li><a href="/#footer">Footer</a></li>
            </ul>
        </div>
    </nav>

<section class="listing">
    <div class="container">
        <div class="form-card">
            <h2>📅 Agendar Nueva Cita</h2>
            <form id="appointment-form">
                <label>Paciente
                    <select id="patient-select" required>
                        <option value="">Seleccione un paciente registrado</option>
                    </select>
                </label>
                
                <div class="two-col">
                    <label>Fecha <input type="date" id="fecha" required /></label>
                    <label>Hora <input type="time" id="hora" required /></label>
                </div>

                <label>Médico Especialista
                    <input type="text" id="medico" placeholder="Ej: Dr. Casas" />
                </label>

                <label>Motivo de la consulta
                    <textarea id="motivo" rows="3" placeholder="Breve descripción..."></textarea>
                </label>

                <button type="submit" class="btn" style="width: 100%;">Confirmar Cita</button>
            </form>
        </div>
    </div>
</section>

    <div id="toast" class="toast hidden"></div>

    <!-- footer included for consistency across pages -->
    <footer id="footer" class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>LEGALES</h4>
                    <ul>
                        <li><a href="#">Portabilidad</a></li>
                        <li><a href="#">Protección de datos</a></li>
                        <li><a href="#">Cuotas moderadoras 2025</a></li>
                        <li><a href="#">Canal Anticorrupción</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>SERVICIOS</h4>
                    <ul>
                        <li><a href="#">Gratuidad en Salud</a></li>
                        <li><a href="#">Municipios autorizados</a></li>
                        <li><a href="#">Consulta de remisiones</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>NORMATIVIDAD</h4>
                    <ul>
                        <li><a href="#">Decreto 780 de 2016</a></li>
                        <li><a href="#">Circular 008 de 2018</a></li>
                        <li><a href="#">Reporte de información</a></li>
                    </ul>
                </div>
                <div class="footer-col footer-contact">
                    <img src="/images/vigilado.svg" alt="Vigilado Supersalud" class="vigilado" style="width: 100px; height: auto; margin-bottom: 1rem;" />
                    <p>Línea Nacional: 018000 114524</p>
                    <div class="social-links">
                        <a href="#">FB</a>
                        <a href="#">TW</a>
                        <a href="#">IG</a>
                        <a href="#">IN</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 IPS Salud - Todos los derechos reservados. Vigilado Supersalud.</p>
            </div>
        </div>
    </footer>

    <script src="/js/funcion.js" is:inline></script>
</body>
</html>